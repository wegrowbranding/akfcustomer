# API Configuration
API_BASE_URL=http://your-api-server.com/api/v1/customer-app
API_STORAGE_URL=http://your-api-server.com/api/v1/media

# Firebase Configuration
FIREBASE_ANALYTICS_ENABLED=true
FIREBASE_CRASHLYTICS_ENABLED=true

# App Configuration
APP_NAME=AK Flowers
APP_VERSION=1.0.0

# Feature Flags
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_DEEP_LINKING=true
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=true

# Debug Configuration
DEBUG_MODE=false
LOG_LEVEL=info
ENABLE_REMOTE_CONFIG=false